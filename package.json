{
  "name": "pylon-kb-mcp-server",
  "version": "1.0.0",
  "description": "MCP server covering Pylon's Knowledge Base API (knowledge bases, collections, articles, route redirects).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pylon-kb-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pylon",
    "knowledge-base",
    "api",
    "claude"
  ],
  "author": "Justin Hein <justin@onboarded.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inheinsight/pylon-kb-mcp.git"
  },
  "homepage": "https://github.com/inheinsight/pylon-kb-mcp#readme",
  "bugs": {
    "url": "https://github.com/inheinsight/pylon-kb-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
